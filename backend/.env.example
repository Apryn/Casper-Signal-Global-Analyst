# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration (Defaults match docker-compose configuration)
DB_USER=casper_user
DB_PASSWORD=casper_password
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=casper_analytics

# Optional DATABASE_URL override (e.g., for Supabase, Neon or staging)
# DATABASE_URL=postgresql://casper_user:casper_password@localhost:5432/casper_analytics

# Security configuration
JWT_SECRET=super_secret_casper_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Telegram configuration
# Get this from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmnoPQRstuvwxyZ_12345678

# Kode aktivasi untuk login dashboard (ganti dengan kode rahasia kamu)
ACTIVATION_CODE=your_secret_activation_code_here

# Gemini API configuration for AI Analytics Report (optional)
# GEMINI_API_KEY=AIzaSy...
